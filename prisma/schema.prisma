generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户表 - 角色权限系统
// ============================================================
model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  displayName   String
  role          String   // reporter | level1_approver | level2_approver | qc_supervisor | admin
  warehouseId   String?  // 所属仓库ID（多租户场景）
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 上报的工单
  reportedTickets      Ticket[]       @relation("Reporter")
  // 审批记录
  approvalRecords      ApprovalRecord[]
  // 扫描记录
  scanRecords          ScanRecord[]

  @@map("users")
}

// ============================================================
// 运单本地快照表（V3自有，只读缓存）
// ============================================================
model WaybillSnapshot {
  id                  String   @id @default(uuid())
  waybillNo           String   @unique // 运单号
  senderName          String   // 发件人
  senderPhone         String   // 发件电话
  senderAddress       String   // 发件地址
  receiverName        String   // 收件人
  receiverPhone       String   // 收件电话
  receiverAddress     String   // 收件地址
  declaredAmount      Float    // 申报金额
  skuInfo             String   // SKU信息JSON
  v2Status            String   // V2侧运单状态
  warehouseId         String?  // 所属仓库
  syncedAt            DateTime // 同步时间
  dataSource          String   @default("v2_api") // v2_api | cache
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tickets  Ticket[]
  scans    ScanRecord[]

  @@map("waybill_snapshots")
}

// ============================================================
// 接口同步日志表
// ============================================================
model ApiSyncLog {
  id            String   @id @default(uuid())
  apiName       String   // 接口名
  requestUrl    String   // 请求URL
  requestParams String?  // 请求参数摘要 JSON
  responseCode  Int?     // 响应码
  responseBody  String?  // 响应体摘要
  isSuccess     Boolean  // 是否成功
  errorMessage  String?  // 错误信息
  duration      Int?     // 耗时ms
  createdAt     DateTime @default(now())

  @@index([apiName])
  @@index([isSuccess])
  @@index([createdAt])
  @@map("api_sync_logs")
}

// ============================================================
// 异常工单表
// ============================================================
model Ticket {
  id              String   @id @default(uuid())
  ticketNo        String   @unique // 工单号
  waybillNo       String   // 关联运单号
  waybillId       String   // 关联运单快照ID
  exceptionType   String   // 异常大类：logistics | quality_control
  exceptionSubtype String  // 异常子类型
  exceptionDesc   String   // 异常描述
  declaredAmount  Float    // 运单金额
  severity        String   @default("normal") // normal | serious | critical
  source          String   // 来源：manual_report | scan_trigger
  status          String   @default("pending") // pending | level1_approving | level2_approving | executing | completed | rejected | closed | force_released
  currentApproverId String? // 当前审批人ID
  resubmitCount   Int      @default(0) // 重提次数
  maxResubmit     Int      @default(3) // 最大重提次数
  isOverdue       Boolean  @default(false)
  overdueAt       DateTime? // 超时时间
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reporterId      String
  reporter        User             @relation("Reporter", fields: [reporterId], references: [id])
  waybill         WaybillSnapshot  @relation(fields: [waybillId], references: [id])
  approvalRecords ApprovalRecord[]
  compensation    Compensation?
  scans           ScanRecord[]

  @@index([waybillNo])
  @@index([status])
  @@index([exceptionType])
  @@index([currentApproverId])
  @@index([createdAt])
  @@map("tickets")
}

// ============================================================
// 审批记录表
// ============================================================
model ApprovalRecord {
  id            String   @id @default(uuid())
  ticketId       String
  approverId    String
  approverName  String
  level         Int      // 1 一级审批 | 2 二级审批
  action        String   // approve | reject
  opinion       String?  // 审批意见
  aiSuggestion  String?  // AI建议
  aiBasis       String?  // AI建议依据
  operationToken String? // 操作令牌（幂等性保证）
  createdAt     DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approver  User   @relation(fields: [approverId], references: [id])

  @@unique([ticketId, level, operationToken]) // 幂等性唯一约束
  @@index([ticketId])
  @@index([approverId])
  @@map("approval_records")
}

// ============================================================
// 赔付记录表
// ============================================================
model Compensation {
  id              String   @id @default(uuid())
  ticketId        String   @unique // 一个工单一条赔付
  amount          Float    // 赔付金额
  direction       String   // 赔付方向：supplier_recovery（向供应商追偿）| customer_compensation（赔付客户）
  status          String   @default("pending") // pending | processing | completed | cancelled
  reconciliationMethod String? // 对账方式
  triggeredBy     String   // 触发审批记录ID
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("compensations")
}

// ============================================================
// 库存表（V3自有）
// ============================================================
model Inventory {
  id              String   @id @default(uuid())
  waybillNo       String
  sku             String   @unique // SKU编号
  productName     String
  quantity        Int      // 当前库存数量
  lockedQuantity  Int      @default(0) // 锁定数量（品控暂扣）
  warehouseId     String?
  status          String   @default("available") // available | locked | returned | scrapped
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  // 库存变更记录
  changes InventoryChange[]

  @@index([waybillNo])
  @@index([sku])
  @@index([warehouseId])
  @@map("inventories")
}

// ============================================================
// 库存变更记录表
// ============================================================
model InventoryChange {
  id              String   @id @default(uuid())
  inventoryId     String
  changeType      String   // lock | unlock | deduct | add | return
  quantity        Int      // 变更数量（正数增加，负数减少）
  beforeQuantity  Int
  afterQuantity   Int
  triggeredBy     String   // 触发审批记录ID
  remark          String?
  createdAt       DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@index([inventoryId])
  @@index([triggeredBy])
  @@map("inventory_changes")
}

// ============================================================
// 扫描记录表（V3自有）
// ============================================================
model ScanRecord {
  id              String   @id @default(uuid())
  waybillNo       String
  waybillId       String
  sku             String   // 扫描的SKU
  operatorId      String   // 操作人ID
  operatorName    String
  deviceInfo      String?  // 设备信息
  qcResult        String   // pass | fail
  exceptionDesc   String?  // 异常描述
  ruleHitId       String?  // 命中的品控规则ID
  batchLocked     Boolean  @default(false) // 批次是否被锁定
  ticketId        String?  // 关联工单ID（异常时非空）
  isDuplicate     Boolean  @default(false) // 是否重复扫描
  aiSuggestion    String?  // AI建议异常类型
  createdAt       DateTime @default(now())

  waybill   WaybillSnapshot @relation(fields: [waybillId], references: [id])
  operator  User             @relation(fields: [operatorId], references: [id])
  ticket    Ticket?          @relation(fields: [ticketId], references: [id])

  @@index([waybillNo])
  @@index([sku])
  @@index([ticketId])
  @@index([createdAt])
  @@map("scan_records")
}

// ============================================================
// 品控规则表（V3自有，可配置）
// ============================================================
model QcRule {
  id              String   @id @default(uuid())
  ruleName        String   // 规则名称
  exceptionSubtype String  // 异常子类型：quantity_mismatch | appearance_damage | spec_mismatch | label_error | batch_abnormal
  triggerField    String   // 触发字段：quantity_diff_percent | damage_level | spec_deviation | label_accuracy | batch_match
  triggerOperator String   // 比较操作符：gt | gte | lt | lte | eq
  triggerValue    Float    // 触发阈值
  severity        String   // 严重度：normal | serious | critical
  autoCreateTicket Boolean @default(true) // 是否自动创建工单
  defaultApprovalLevel Int @default(1)    // 默认进入审批级别
  isActive        Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("qc_rules")
}

// ============================================================
// 系统配置表
// ============================================================
model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique // 配置键
  value     String   // 配置值 JSON
  description String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_configs")
}
